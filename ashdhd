<!DOCTYPE html>
<html lang="pt">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Grupo de Assobios</title>

<style>
body{
  background:#111;
  color:white;
  font-family:Arial;
  text-align:center;
  padding:20px;
}

.box{
  background:#222;
  padding:20px;
  border-radius:20px;
  max-width:700px;
  margin:auto;
}

input{
  width:70%;
  padding:10px;
  border:none;
  border-radius:10px;
}

button{
  padding:10px;
  border:none;
  border-radius:10px;
  background:limegreen;
  color:white;
  cursor:pointer;
}

li{
  list-style:none;
  background:#333;
  margin:10px;
  padding:10px;
  border-radius:10px;
}
</style>
</head>

<body>

<div class="box">

<h1>📢 Grupo de Assobios</h1>

<input id="ruleInput" placeholder="Escreve uma regra">
<button onclick="addRule()">Adicionar</button>

<ul id="rules"></ul>

</div>

<script type="module">

import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js";
import { getFirestore, collection, addDoc, onSnapshot } 
from "https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore.js";

// 🔥 Firebase config (corrigido e pronto a usar)
const firebaseConfig = {
  apiKey: "AIzaSyAjsBEsMvB8DOAQuuy3OoqVuc1rJndBh4A",
  authDomain: "assobio-32dc1.firebaseapp.com",
  projectId: "assobio-32dc1",
  storageBucket: "assobio-32dc1.appspot.com",
  messagingSenderId: "632711724733",
  appId: "1:632711724733:web:9e686877df41fe2c8ac1d4",
  measurementId: "G-QEM1B6KK4Y"
};

// Init Firebase
const app = initializeApp(firebaseConfig);
const db = getFirestore(app);

// Adicionar regra
window.addRule = async function () {
  const input = document.getElementById("ruleInput");

  if (input.value.trim() !== "") {
    await addDoc(collection(db, "rules"), {
      text: input.value,
      time: Date.now()
    });

    input.value = "";
  }
};

// Mostrar regras em tempo real
const rulesList = document.getElementById("rules");

onSnapshot(collection(db, "rules"), (snapshot) => {
  rulesList.innerHTML = "";

  snapshot.forEach((doc) => {
    const li = document.createElement("li");
    li.textContent = doc.data().text;
    rulesList.appendChild(li);
  });
});

</script>

</body>
</html>
